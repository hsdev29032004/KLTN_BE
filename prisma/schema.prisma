generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String           @id @default(uuid())
  fullName                 String
  email                    String           @unique
  password                 String
  avatar                   String?
  banId                    String?
  roleId                   String
  isDeleted                Boolean          @default(false)
  timeBan                  DateTime?
  timeUnBan                DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  deletedAt                DateTime?
  refreshToken             String?
  availableAmount          Int?             @default(0)
  slug                     String           @unique
  introduce                String           @default("")
  processedReports         CourseReport[]   @relation("processor")
  reports                  CourseReport[]
  reviews                  CourseReview[]
  publishedCourses         Course[]         @relation("CoursePublishedBy")
  courses                  Course[]
  invoices                 Invoices[]
  publishedLessonMaterials LessonMaterial[] @relation("LessonMaterialPublishedBy")
  publishedLessons         Lesson[]         @relation("LessonPublishedBy")
  messages                 Message[]
  transactions             Transaction[]
  userCourses              UserCourse[]
  conversationMembers      ConversationMember[]
  teacherApprovals         CourseApproval[] @relation("teacherApprovals")
  adminApprovals           CourseApproval[] @relation("adminApprovals")
  publishedExams           Exam[]           @relation("ExamPublishedBy")
  examAttempts             ExamAttempt[]
  ban                      Ban?             @relation(fields: [banId], references: [id])
  role                     Role             @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  api             String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  methods      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Ban {
  id        String    @id @default(uuid())
  reason    String
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  users     User[]

  @@map("bans")
}

model Course {
  id              String            @id @default(uuid())
  name            String
  price           Int
  thumbnail       String
  content         String
  slug            String            @unique
  description     String
  status          CourseStatus      @default(draft)
  studentCount    Int               @default(0)
  star            Decimal           @db.Decimal(2, 1)
  userId          String
  publishedBy     String?
  isDeleted       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  publishedAt     DateTime?
  conversation    Conversation?
  reports         CourseReport[]
  reviews         CourseReview[]
  courseTopics    CourseTopic[]
  publisher       User?             @relation("CoursePublishedBy", fields: [publishedBy], references: [id])
  user            User              @relation(fields: [userId], references: [id])
  detail_invoices DetailInvoices[]
  lessons         Lesson[]
  userCourses     UserCourse[]
  approvals       CourseApproval[]
  exams           Exam[]

  @@map("courses")
}

model Lesson {
  id          String           @id @default(uuid())
  courseId    String
  name        String
  status      LessonStatus     @default(draft)
  publisherId String?
  isDeleted   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  publishedAt DateTime?
  materials   LessonMaterial[]
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  publisher   User?            @relation("LessonPublishedBy", fields: [publisherId], references: [id])

  @@map("lessons")
}

model LessonMaterial {
  id          String       @id @default(uuid())
  lessonId    String
  type        MaterialType
  name        String
  url         String
  status      LessonStatus @default(draft)
  publisherId String?
  isDeleted   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  publishedAt DateTime?
  isPreview   Boolean      @default(false)
  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  publisher   User?        @relation("LessonMaterialPublishedBy", fields: [publisherId], references: [id])

  @@map("lesson_materials")
}

model Topic {
  id        String        @id @default(uuid())
  name      String
  slug      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  courses   CourseTopic[]

  @@map("topics")
}

model CourseTopic {
  id        String   @id @default(uuid())
  courseId  String
  topicId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([courseId, topicId])
  @@map("course_topics")
}

model Conversation {
  id        String    @id @default(uuid())
  name      String    @default("")
  courseId  String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  messages  Message[]
  members   ConversationMember[]

  @@map("conversations")
}

model ConversationMember {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  isHost         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])

  @@map("messages")
}

model CourseReview {
  id         String    @id @default(uuid())
  reviewerId String
  courseId   String
  rating     Int
  content    String
  isDeleted  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  reviewer   User      @relation(fields: [reviewerId], references: [id])

  @@map("course_reviews")
}

model CourseReport {
  id          String             @id @default(uuid())
  courseId    String
  reporterId  String
  processorId String?
  reason      String
  status      CourseReportStatus @default(pending)
  isDeleted   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  course      Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  processor   User?              @relation("processor", fields: [processorId], references: [id])
  reporter    User               @relation(fields: [reporterId], references: [id])

  @@map("course_reports")
}

model Invoices {
  id              String               @id(map: "course_purchases_pkey") @default(uuid())
  userId          String
  amount          Int
  status          CoursePurchaseStatus @default(purchased)
  isDeleted       Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  detail_invoices DetailInvoices[]
  users           User                 @relation(fields: [userId], references: [id], map: "course_purchases_userId_fkey")

  @@map("invoices")
}

model UserCourse {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("user_courses")
}

model Transaction {
  id            String            @id @default(uuid())
  userId        String
  type          TransactionType
  amount        Int
  bankName      String?
  accountNumber String?
  status        TransactionStatus @default(pending)
  isDeleted     Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  user          User              @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model System {
  id            String   @id @default("system")
  comissionRate Decimal  @db.Decimal(5, 2)
  term          String
  contact       String   @default("")
  updatedAt     DateTime @updatedAt
  banks         Bank[]

  @@map("systems")
}

model Bank {
  id         String    @id @default(uuid())
  systemId   String
  bankNumber String
  bankName   String
  recipient  String
  isDeleted  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  system     System    @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@map("banks")
}

model DetailInvoices {
  id               String         @id(map: "invoices_pkey") @default(uuid())
  coursePurchaseId String
  courseId         String
  price            Int
  commissionRate   Decimal        @default(0) @db.Decimal(5, 2)
  status           String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  courses          Course         @relation(fields: [courseId], references: [id], onDelete: Cascade, map: "invoices_courseId_fkey")
  invoices         Invoices @relation(fields: [coursePurchaseId], references: [id], onDelete: Cascade, map: "invoices_coursePurchaseId_fkey")

  @@unique([coursePurchaseId, courseId], map: "invoices_coursePurchaseId_courseId_key")

  @@map("detail_invoices")
}

model CourseApproval {
  id          String               @id @default(uuid())
  courseId     String
  teacherId   String
  description String
  status      CourseApprovalStatus @default(pending)
  reason      String?
  adminId     String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  course      Course               @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher     User                 @relation("teacherApprovals", fields: [teacherId], references: [id])
  admin       User?                @relation("adminApprovals", fields: [adminId], references: [id])

  @@map("course_approvals")
}

model Exam {
  id              String       @id @default(uuid())
  courseId         String
  name            String
  passPercent     Int          // % hoàn thiện để pass
  retryAfterDays  Int          // số ngày có thể làm lại
  questionCount   Int          // số câu hỏi lấy ngẫu nhiên mỗi lần thi
  duration        Int          // thời gian làm bài (phút)
  status          LessonStatus @default(draft)
  publisherId     String?
  isDeleted       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?
  publishedAt     DateTime?
  course          Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  publisher       User?        @relation("ExamPublishedBy", fields: [publisherId], references: [id])
  questions       ExamQuestion[]
  attempts        ExamAttempt[]

  @@map("exams")
}

model ExamQuestion {
  id            String   @id @default(uuid())
  examId        String
  content       String   // đề bài
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String   // "A" | "B" | "C" | "D"
  isDeleted     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  attemptAnswers ExamAttemptAnswer[]

  @@map("exam_questions")
}

model ExamAttempt {
  id          String              @id @default(uuid())
  examId      String
  userId      String
  score       Decimal?            @db.Decimal(5, 2) // % điểm
  isPassed    Boolean             @default(false)
  isCompleted Boolean             @default(false) // đã nộp bài chưa
  startedAt   DateTime            @default(now())
  submittedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  exam        Exam                @relation(fields: [examId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id])
  answers     ExamAttemptAnswer[]

  @@map("exam_attempts")
}

model ExamAttemptAnswer {
  id            String       @id @default(uuid())
  attemptId     String
  questionId    String
  selectedAnswer String?     // "A" | "B" | "C" | "D" hoặc null nếu chưa trả lời
  isCorrect     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  attempt       ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question      ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@map("exam_attempt_answers")
}

enum CourseApprovalStatus {
  pending
  approved
  rejected
}

enum CourseStatus {
  draft
  pending
  published
  deleted
  update
  outdated
  rejected
  need_update
}

enum LessonStatus {
  draft
  pending
  published
  outdated
  deleted
}

enum MaterialType {
  video
  pdf
  img
  link
  other
}

enum CourseReportStatus {
  pending
  resolved
  dismissed
}

enum CoursePurchaseStatus {
  purchased
  refund_requested
  refunded
}

enum TransactionType {
  deposit
  withdrawal
}

enum TransactionStatus {
  pending
  completed
  failed
  approved
  rejected
}
