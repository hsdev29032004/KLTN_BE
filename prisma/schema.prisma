generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String           @id @default(uuid())
  fullName                 String
  email                    String           @unique
  password                 String
  avatar                   String?
  banId                    String?
  roleId                   String
  isDeleted                Boolean          @default(false)
  timeBan                  DateTime?
  timeUnBan                DateTime?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  deletedAt                DateTime?
  refreshToken             String?
  availableAmount          Int?             @default(0)
  lockAmount               Int?             @default(0)
  slug                     String           @unique
  coursePurchases          CoursePurchase[]
  processedReports         CourseReport[]   @relation("processor")
  reports                  CourseReport[]
  reviews                  CourseReview[]
  publishedCourses         Course[]         @relation("CoursePublishedBy")
  courses                  Course[]
  publishedLessonMaterials LessonMaterial[] @relation("LessonMaterialPublishedBy")
  publishedLessons         Lesson[]         @relation("LessonPublishedBy")
  messages                 TicketMessage[]
  ticketsAsReceiver        Ticket[]         @relation("TicketReceiver")
  ticketsAsSender          Ticket[]         @relation("TicketSender")
  transactions             Transaction[]
  ban                      Ban?             @relation(fields: [banId], references: [id])
  role                     Role             @relation(fields: [roleId], references: [id])

  @@map("users")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  api             String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  methods      String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Ban {
  id        String    @id @default(uuid())
  reason    String
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  users     User[]

  @@map("bans")
}

model Course {
  id               String           @id @default(uuid())
  name             String
  price            Int
  thumbnail        String
  content          String
  slug             String           @unique
  description      String
  status           CourseStatus     @default(draft)
  studentCount     Int              @default(0)
  star             Decimal          @db.Decimal(2, 1)
  userId           String
  publishedBy      String?
  isDeleted        Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  publishedAt      DateTime?
  detailsInvoices  DetailsInvoice[]
  reports          CourseReport[]
  reviews          CourseReview[]
  courseTopics     CourseTopic[]
  publisher        User?            @relation("CoursePublishedBy", fields: [publishedBy], references: [id])
  user             User             @relation(fields: [userId], references: [id])
  lessons          Lesson[]

  @@map("courses")
}

model Lesson {
  id          String           @id @default(uuid())
  courseId    String
  name        String
  status      LessonStatus     @default(draft)
  publisherId String?
  isDeleted   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  publishedAt DateTime?
  materials   LessonMaterial[]
  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  publisher   User?            @relation("LessonPublishedBy", fields: [publisherId], references: [id])
  tickets     Ticket[]

  @@map("lessons")
}

model LessonMaterial {
  id          String       @id @default(uuid())
  lessonId    String
  type        MaterialType
  name        String
  url         String
  status      LessonStatus @default(draft)
  publisherId String?
  isDeleted   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  publishedAt DateTime?
  isPreview   Boolean      @default(false)
  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  publisher   User?        @relation("LessonMaterialPublishedBy", fields: [publisherId], references: [id])

  @@map("lesson_materials")
}

model Topic {
  id        String        @id @default(uuid())
  name      String
  slug      String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  courses   CourseTopic[]

  @@map("topics")
}

model CourseTopic {
  id        String   @id @default(uuid())
  courseId  String
  topicId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([courseId, topicId])
  @@map("course_topics")
}

model Ticket {
  id         String          @id @default(uuid())
  lessonId   String
  senderId   String
  receiverId String
  title      String
  isClosed   Boolean         @default(false)
  isDeleted  Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deletedAt  DateTime?
  messages   TicketMessage[]
  lesson     Lesson          @relation(fields: [lessonId], references: [id])
  receiver   User            @relation("TicketReceiver", fields: [receiverId], references: [id])
  sender     User            @relation("TicketSender", fields: [senderId], references: [id])

  @@map("tickets")
}

model TicketMessage {
  id        String    @id @default(uuid())
  ticketId  String
  senderId  String
  content   String
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  sender    User      @relation(fields: [senderId], references: [id])
  ticket    Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_messages")
}

model CourseReview {
  id         String    @id @default(uuid())
  reviewerId String
  courseId   String
  rating     Int
  content    String
  isDeleted  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  course     Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  reviewer   User      @relation(fields: [reviewerId], references: [id])

  @@map("course_reviews")
}

model CourseReport {
  id          String             @id @default(uuid())
  courseId    String
  reporterId  String
  processorId String?
  reason      String
  status      CourseReportStatus @default(pending)
  isDeleted   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  course      Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  processor   User?              @relation("processor", fields: [processorId], references: [id])
  reporter    User               @relation(fields: [reporterId], references: [id])

  @@map("course_reports")
}

model CoursePurchase {
  id        String               @id @default(uuid())
  userId    String
  amount    Int
  status    CoursePurchaseStatus @default(purchased)
  isDeleted Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  deletedAt DateTime?
  user      User                 @relation(fields: [userId], references: [id])
  invoices  DetailsInvoice[]

  @@map("course_purchases")
}
model DetailsInvoice {
  id               String   @id @default(uuid())
  coursePurchaseId String
  courseId         String
  price            Int
  status           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  coursePurchase   CoursePurchase @relation(fields: [coursePurchaseId], references: [id], onDelete: Cascade)
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([coursePurchaseId, courseId])
  @@map("invoices")
}

model Transaction {
  id            String            @id @default(uuid())
  userId        String
  type          TransactionType
  amount        Int
  bankName      String?
  accountNumber String?
  status        TransactionStatus @default(pending)
  isDeleted     Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  user          User              @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model System {
  id            String   @id @default("system")
  timeRefund    Int
  limitRefund   Int
  comissionRate Decimal  @db.Decimal(5, 2)
  term          String
  updatedAt     DateTime @updatedAt
  banks         Bank[]

  @@map("systems")
}

model Bank {
  id         String    @id @default(uuid())
  systemId   String
  bankNumber String
  bankName   String
  recipient  String
  isDeleted  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  system     System    @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@map("banks")
}

enum CourseStatus {
  draft
  pending
  published
}

enum LessonStatus {
  draft
  pending
  published
}

enum MaterialType {
  video
  pdf
  img
  link
  other
}

enum CourseReportStatus {
  pending
  resolved
  dismissed
}

enum CoursePurchaseStatus {
  purchased
  refund_requested
  refunded
}

enum TransactionType {
  deposit
  withdrawal
}

enum TransactionStatus {
  pending
  completed
  failed
  approved
  rejected
}
